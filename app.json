{
  "expo": {
    "name": "users-mobile",
    "slug": "users-mobile",
    "scheme": "udesamigos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-udesamigos.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-udesamigos.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para descubrir usuarios cercanos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo-udesamigos.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/logo-udesamigos.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos tu ubicación para descubrir usuarios cercanos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4903d743-3879-493a-bd69-052c8fa0bf6b"
      }
    },
    "owner": "tutecostantini"
  }
}
