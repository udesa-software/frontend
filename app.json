{
  "expo": {
    "name": "users-mobile",
    "slug": "users-mobile",
    "scheme": "udesamigos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-udesamigos.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-udesamigos.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicaci\u00f3n para descubrir usuarios cercanos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo-udesamigos.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/logo-udesamigos.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos tu ubicaci\u00f3n para descubrir usuarios cercanos."
        }
      ]
    ]
  }
}
